{
  "name": "timer-app",
  "version": "1.0.0",
  "description": "Desktop alarm progress timer",
  "main": "main.js",
  "scripts": {
    "prebuild": "node scripts/generate-icon.js",
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.timerapp.desktop",
    "productName": "Timer App",
    "icon": "build/icon.ico",
    "files": [
      "**/*",
      "!dist/**"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5"
  }
}
